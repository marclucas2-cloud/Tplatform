{
  "strategy_id": "rsi_filtered_v1",
  "version": "1.0.0",
  "created_at": "2026-03-22T00:00:00Z",
  "description": "RSI mean reversion filtré par ADX. Ne trade que lorsque le marché est en range (ADX faible). Élimine les faux signaux en tendance forte.",
  "asset": "CS.D.EURUSD.MINI.IP",
  "timeframe": "1H",
  "parameters": {
    "rsi_period": 14,
    "oversold": 28,
    "overbought": 72,
    "adx_period": 14,
    "adx_threshold": 22,
    "stop_loss_pct": 0.4,
    "take_profit_pct": 0.8,
    "max_position_pct": 0.02
  },
  "entry_rules": {
    "long":  "adx < adx_threshold AND rsi crosses above oversold",
    "short": "adx < adx_threshold AND rsi crosses below overbought"
  },
  "exit_rules": {
    "long":  "rsi > 50 OR stop_loss OR take_profit",
    "short": "rsi < 50 OR stop_loss OR take_profit"
  },
  "cost_model": {
    "spread_pips": 0.8,
    "slippage_pips": 0.3,
    "commission_per_lot": 0.0
  },
  "validation_requirements": {
    "min_trades": 40,
    "min_sharpe": 0.5,
    "max_drawdown_pct": 15,
    "walk_forward_windows": 4,
    "out_of_sample_pct": 30,
    "min_profit_factor": 1.15
  },
  "risk_management": {
    "max_position_pct": 0.02,
    "max_open_trades": 1,
    "daily_loss_limit_pct": 0.02
  },
  "tags": ["mean_reversion", "forex", "rsi", "adx_filter", "intraday"]
}
