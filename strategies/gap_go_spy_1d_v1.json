  "description": "Gap and Go sur SPY daily. Detecte les gaps > 1% avec continuation confirmee (bougie dans le sens du gap + volume eleve). Entre le jour suivant pour capter le momentum residuel. Gaps > 5% exclus (trop impredictibles).",
  "asset": "SPY",
  "timeframe": "1D",
  "parameters": {
    "gap_threshold_pct": 1.0,
    "max_gap_pct": 5.0,
    "volume_multiplier": 1.5,
    "volume_lookback": 20,
    "stop_loss_pct": 1.0,
    "take_profit_pct": 2.0,
    "trailing_stop_pct": 0.5,
    "max_position_pct": 0.01
  },
  "entry_rules": {
    "long": "Gap up > 1% AND close > open (continuation) AND volume > 1.5x avg",
    "short": "Gap down > 1% AND close < open (continuation) AND volume > 1.5x avg"
  },
  "exit_rules": {
    "long": "stop_loss(-1.0%) OR take_profit(+2.0%) OR trailing_stop(0.5%)",
    "short": "stop_loss(+1.0%) OR take_profit(-2.0%) OR trailing_stop(0.5%)"
  },
  "cost_model": {
    "spread_pct": 0.01,
    "slippage_pct": 0.02,
