    "take_profit_pct": 1.5,
    "trailing_stop_pct": 0.4,
    "max_position_pct": 0.01
  },
  "entry_rules": {
    "long": "Gap down 1-3% AND volume < 1.5x avg (no catalyst) -> expect gap fill",
    "short": "Gap up 1-3% AND volume < 1.5x avg (no catalyst) -> expect gap fill"
  },
  "exit_rules": {
    "long": "stop_loss(-1.5%) OR take_profit(+1.5%) OR trailing_stop(0.4%)",
    "short": "stop_loss(+1.5%) OR take_profit(-1.5%) OR trailing_stop(0.4%)"
  },
