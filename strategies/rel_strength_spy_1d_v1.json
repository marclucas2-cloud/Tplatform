    "stop_loss_pct": 1.5,
    "take_profit_pct": 3.0,
    "trailing_stop_pct": 0.6,
    "max_position_pct": 0.01
  },
  "entry_rules": {
    "long": "ROC(5) > 2% AND ROC(20) > 0 AND volume > 1.5x avg (accelerating uptrend)",
    "short": "ROC(5) < -2% AND ROC(20) < 0 AND volume > 1.5x avg (accelerating downtrend)"
  },
  "exit_rules": {
    "long": "stop_loss(-1.5%) OR take_profit(+3.0%) OR trailing_stop(0.6%)",
    "short": "stop_loss(+1.5%) OR take_profit(-3.0%) OR trailing_stop(0.6%)"
  },
