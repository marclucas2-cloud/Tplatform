  "exit_rules": {
    "long": "trailing_stop=0.25% OU take_profit=1.2% OU stop_loss=0.5%",
    "short": "trailing_stop=0.25% OU take_profit=1.2% OU stop_loss=0.5%"
  },
  "cost_model": {
