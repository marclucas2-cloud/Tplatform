    "trailing_stop_pct": 0.5,
    "max_position_pct": 0.01
  },
  "entry_rules": {
    "long": "RSI(2) was < 5 and recovering AND close > SMA(200) (uptrend)",
    "short": "RSI(2) was > 95 and declining AND close < SMA(200) (downtrend)"
  },
  "exit_rules": {
    "long": "stop_loss(-1.5%) OR take_profit(+2.0%) OR trailing_stop(0.5%)",
    "short": "stop_loss(+1.5%) OR take_profit(-2.0%) OR trailing_stop(0.5%)"
  },
