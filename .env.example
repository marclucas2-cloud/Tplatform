# ============================================================
# Trading Platform — Variables d'environnement
# Copier en .env et remplir avant de lancer
# NE JAMAIS committer .env
# ============================================================

# --- IG Markets ---
IG_API_KEY=your_ig_api_key_here
IG_USERNAME=your_ig_username
IG_PASSWORD=your_ig_password
IG_ACC_TYPE=DEMO              # DEMO ou LIVE
IG_ACC_NUMBER=your_account_number
# Base URL selon compte :
# DEMO : https://demo-api.ig.com/gateway/deal
# LIVE : https://api.ig.com/gateway/deal
IG_BASE_URL=https://demo-api.ig.com/gateway/deal

# --- Anthropic (Research Agent LLM) ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Paramètres système ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
PAPER_TRADING=true            # true = paper trading, false = live (DANGER)
MAX_RISK_PER_TRADE=0.02       # 2% du capital max par trade
MAX_DAILY_DRAWDOWN=0.05       # Coupe-circuit : stop si -5% sur la journée

# --- Base de données (optionnel — SQLite par défaut) ---
# DATABASE_URL=postgresql://user:pass@host:5432/trading
DATABASE_URL=sqlite:///trading.db
